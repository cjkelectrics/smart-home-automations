alias: Bedroom Light Wake Up
description: Gradually turns on bedroom light at 7am
trigger:
  - platform: time
    at: "07:00:00"

condition: []

action:
  - service: light.turn_on
    target:
      entity_id: light.bedroom_light
    data:
      brightness: 255
      transition: 300  # 5 minutes fade-in

mode: single