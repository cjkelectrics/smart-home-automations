blueprint:
  name: Party Mode Toggle Lights
  description: Toggle party lights using a helper toggle
  domain: automation

  input:
    party_toggle:
      name: Party Mode Toggle
      description: Select your input_boolean helper
      selector:
        entity:
          domain: input_boolean

    party_lights:
      name: Lights
      selector:
        target:
          entity:
            domain: light

    flash_interval:
      name: Speed
      default: 0.5
      selector:
        number:
          min: 0.1
          max: 5
          unit_of_measurement: seconds

mode: restart

trigger:
  - platform: state
    entity_id: !input party_toggle

action:
  - choose:
      - conditions:
          - condition: state
            entity_id: !input party_toggle
            state: "on"
        sequence:
          - repeat:
              while:
                - condition: state
                  entity_id: !input party_toggle
                  state: "on"
              sequence:
                - service: light.turn_on
                  target: !input party_lights
                  data:
                    brightness: 255
                    transition: !input flash_interval
                    color_name: >
                      {% set colors = ['red','green','blue','yellow','purple','orange','pink','cyan'] %}
                      {{ colors | random }}
                - delay:
                    seconds: !input flash_interval

      - conditions:
          - condition: state
            entity_id: !input party_toggle
            state: "off"
        sequence:
          - service: light.turn_off
            target: !input party_lights