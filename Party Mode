blueprint:
  name: Party Mode Toggle Lights
  description: Toggle a party mode that flashes colored lights with smooth transitions until stopped.
  domain: automation
  input:
    party_toggle_button:
      name: Party Mode Button
      description: Button to start/stop party mode
      selector:
        entity:
          domain: button
    party_lights:
      name: Lights to Flash
      description: Select all lights to flash
      selector:
        target:
          entity:
            domain: light
    flash_interval:
      name: Flash Interval
      description: Time (in seconds) between color changes
      default: 0.5
      selector:
        number:
          min: 0.1
          max: 5
          unit_of_measurement: seconds
          mode: slider

mode: parallel
max_exceeded: silent

variables:
  party_mode: "{{ state('input_boolean.party_mode') | default('off') }}"

trigger:
  - platform: state
    entity_id: !input party_toggle_button
    to: "pressed"

action:
  - choose:
      - conditions:
          - condition: state
            entity_id: input_boolean.party_mode
            state: "off"
        sequence:
          - service: input_boolean.turn_on
            target:
              entity_id: input_boolean.party_mode
          - repeat:
              while:
                - condition: state
                  entity_id: input_boolean.party_mode
                  state: "on"
              sequence:
                - service: light.turn_on
                  target: !input party_lights
                  data:
                    brightness: 255
                    transition: !input flash_interval
                    color_name: >
                      {% set colors = ['red','green','blue','yellow','purple','orange','pink','cyan'] %}
                      {{ colors | random }}
                - delay: "00:00:{{ !input flash_interval }}"
      - conditions:
          - condition: state
            entity_id: input_boolean.party_mode
            state: "on"
        sequence:
          - service: input_boolean.turn_off
            target:
              entity_id: input_boolean.party_mode
          - service: light.turn_off
            target: !input party_lights