blueprint:
  name: Away Mode Presence Simulation
  description: Simulate someone being home by randomly turning lights on/off.
  domain: automation
  input:
    away_mode_toggle:
      name: Away Mode Toggle
      selector:
        entity:
          domain: input_boolean
    lights:
      name: Lights to simulate presence
      selector:
        target:
          entity:
            domain: light
mode: restart
trigger:
  - platform: state
    entity_id: !input away_mode_toggle
    to: 'on'
condition: []
action:
  - repeat:
      until:
        - condition: state
          entity_id: !input away_mode_toggle
          state: 'off'
      sequence:
        - variables:
            selected_light: "{{ expand(!input.lights)|random }}"
            brightness: "{{ range(40,100)|random }}"
        - service: light.turn_on
          target:
            entity_id: "{{ selected_light.entity_id }}"
          data:
            brightness_pct: "{{ brightness }}"
        - delay:
            minutes: "{{ range(5,25)|random }}"
        - service: light.turn_off
          target:
            entity_id: "{{ selected_light.entity_id }}"
        - delay:
            minutes: "{{ range(1,5)|random }}"