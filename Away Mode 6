blueprint:
  name: Away Mode - Presence Simulation
  description: >
    Simulates occupancy by randomly turning lights on and off when away mode is enabled.
  domain: automation

  input:
    away_mode:
      name: Away Mode Entity
      description: Input boolean or switch to activate away mode
      selector:
        entity:
          domain:
            - input_boolean
            - switch

    target_lights:
      name: Lights to Simulate
      description: Choose lights to control
      selector:
        target:
          entity:
            domain: light

    start_time:
      name: Start Time
      default: "18:00:00"
      selector:
        time: {}

    end_time:
      name: End Time
      default: "23:30:00"
      selector:
        time: {}

trigger:
  - platform: time_pattern
    minutes: "/10"

condition:
  - condition: state
    entity_id: !input away_mode
    state: "on"

  - condition: time
    after: !input start_time
    before: !input end_time

action:
  - variables:
      lights: !input target_lights

  - choose:
      - conditions:
          - condition: template
            value_template: "{{ (range(0, 100) | random) > 50 }}"
        sequence:
          - service: light.turn_on
            target: !input target_lights
            data:
              brightness_pct: "{{ range(40, 90) | random }}"
      - conditions:
          - condition: template
            value_template: "{{ (range(0, 100) | random) <= 50 }}"
        sequence:
          - service: light.turn_off
            target: !input target_lights

mode: single