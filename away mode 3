blueprint:
  name: Away Mode Presence Simulation
  description: Turns lights on/off randomly to simulate someone being home when Away Mode is active.
  domain: automation
  input:
    away_mode_toggle:
      name: Away Mode Toggle
      description: Activate this input_boolean to enable presence simulation
      selector:
        entity:
          domain: input_boolean
    lights:
      name: Lights to simulate presence
      description: List of lights to turn on/off randomly
      selector:
        target:
          entity:
            domain: light
    start_time:
      name: Simulation Start Time
      description: Time to start presence simulation
      default: "18:30:00"
      selector:
        time:
    end_time:
      name: Simulation End Time
      description: Time to stop presence simulation
      default: "23:00:00"
      selector:
        time
    random_minute_variation:
      name: Random Minute Variation
      description: Random offset for lights to make it realistic
      default: 5
      selector:
        number:
          min: 0
          max: 15
          unit_of_measurement: minutes

trigger:
  - platform: time
    at: !input start_time

condition:
  - condition: state
    entity_id: !input away_mode_toggle
    state: "on"

action:
  - repeat:
      until:
        - condition: time
          after: !input end_time
      sequence:
        - variables:
            delay_minutes: "{{ range(-1 * !input.random_minute_variation, !input.random_minute_variation + 1)|random }}"
            selected_light: "{{ expand(!input.lights) | random }}"
            brightness: "{{ range(40,100)|random }}"
        - service: light.turn_on
          target:
            entity_id: "{{ selected_light.entity_id }}"
          data:
            brightness_pct: "{{ brightness }}"
        - delay:
            minutes: "{{ range(5,25)|random }}"
        - service: light.turn_off
          target:
            entity_id: "{{ selected_light.entity_id }}"
        - delay:
            minutes: "{{ range(1,5)|random }}"
mode: restart