alias: Evening Ambient Lights
description: Turn on ambient lights in the evening
trigger:
  - platform: time
    at: "19:00:00"  # Change this to the time you want lights to turn on
condition: []
action:
  - service: light.turn_on   # Use switch.turn_on if your device is a switch
    target:
      entity_id:
        - light.living_room_ambient  # Replace with your correct entity ID
        - light.bedroom_ambient      # Add more lights if needed
    data:
      brightness: 150               # Optional: adjust brightness 0-255
      color_temp: 350               # Optional: adjust color temperature
mode: single
   