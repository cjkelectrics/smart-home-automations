blueprint:
  name: Evening Ambient Lighting
  description: Turns lights on at a chosen evening time with adjustable brightness and color temperature
  domain: automation

  input:
    light_target:
      name: Light
      description: The light to turn on
      selector:
        entity:
          domain: light

    trigger_time:
      name: Trigger Time
      description: Time to turn on lights in the evening
      default: "19:00:00"
      selector:
        time: {}

    brightness_level:
      name: Brightness
      description: Brightness level (0-255)
      default: 120
      selector:
        number:
          min: 0
          max: 255
          unit_of_measurement: "brightness"

    color_temp_level:
      name: Color Temperature
      description: Color temperature in mireds
      default: 400
      selector:
        number:
          min: 153
          max: 500
          unit_of_measurement: "mireds"

trigger:
  - platform: time
    at: !input trigger_time

action:
  - service: light.turn_on
    target:
      entity_id: !input light_target
    data:
      brightness: !input brightness_level
      color_temp: !input color_temp_level

mode: single